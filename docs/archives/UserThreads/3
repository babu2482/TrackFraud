// Helper to parse ID fields
function parseIDField(
  idType?: string,
  idNumber?: string,
  country?: string,
): Array<{ idType: string; idNumber: string; issuingCountry: string }> {
  if (!idNumber) return [];

  const result = [{ idType: idType || "Unknown", idNumber, issuingCountry: country || "Unknown" }];

  // Handle multi-line ID numbers (split by newline or semicolon)
  if (idNumber.includes("\n") || idNumber.includes(";")) {
    const parts = idNumber.split(/[\n;]+/).filter(Boolean);
    return parts.map((part: string, idx: number) => ({
      idType: idType || "Unknown",
      idNumber: part.trim(),
      issuingCountry: country || "Unknown",
    }));
