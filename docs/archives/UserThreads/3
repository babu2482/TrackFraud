// Parse JSON record from OFAC consolidated format
function parseJSONRecord(record: any): ParsedSanction {
  const addresses = (record.Address || []).map((addr: any) => ({
    address: addr.address,
    city: addr.city,
    stateOrProvince: addr.state_or_province,
    postalCode: addr.postal_code,
    country: addr.country,
  }));

  const ids = [
    ...parseIDField(record.id_type_1, record.id_number_1, record.id_country_1),
    ...parseIDField(
      record.id_type_2,
      record.id_number_2,
      record.id_country_2,
    ),
  ].filter((id: any) => id.idNumber);

  const datesOfBirth = (record.date_of_birth || []).filter(Boolean);
  const placesOfBirth = (record.place_of_birth || []).filter(Boolean);
  const citizenCountries = (record.citizenship || []).filter(Boolean);

  return {
    ofacId: record.sdn_id.toString(),
    programs: Array.isArray(record.program)
