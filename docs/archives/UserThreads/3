  if (state.failedSteps.size > 0) {
    console.log("\n⚠️ Failed Steps:");

    for (const [stepId, error] of state.failedSteps.entries()) {
      console.log(`  - ${stepId}: ${error.message}`);
    }
  }

  console.log("\n📖 Next Steps:");
