      id: true,
      signalKey: true,
      severity: true,
      detail: true,
      createdAt: true,
    },
    orderBy: { createdAt: "desc" },
  });

  return signals.map((s) => ({
    id: s.id,
    signalType: s.signalKey,
    severity: s.severity as SignalSeverity,
    description: s.detail || "",
    createdAt: s.createdAt,
