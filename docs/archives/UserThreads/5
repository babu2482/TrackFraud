                        )}
                        {(result.city || result.state) && (
                          <span>{result.city}{result.city && result.state ? ", " : ""}{result.state}</span>
                        )}
                        {result.nteeCode && (
                          <span>NTEE: {result.nteeCode}</span>
                        )}
                        {result.industry && (
                          <span>Industry: {result.industry}</span>
                        )}
                      </div>

                      {/* Risk indicators */}
                      {(result.riskScore !== undefined || result.regulatoryActionsCount) && (
