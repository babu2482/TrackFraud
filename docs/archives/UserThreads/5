      case "recipientState":
        orderBy.recipientState = sortOrder;
        break;
      case "paymentDate":
        orderBy.paymentDate = sortOrder;
        break;
      default:
        orderBy.paymentDate = sortOrder;
    }

    // Fetch payments with pagination
    const [payments, total] = await Promise.all([
      prisma.healthcarePaymentRecord.findMany({
        where,
        skip: offset,
        take: limit,
        orderBy,
        select: {
          id: true,
          recipientName: true,
          recipientType: true,
          recipientState: true,
          recipientZip: true,
          specialty: true,
          paymentAmount: true,
          paymentDate: true,
          paymentDescription: true,
          npi: true,
          teachingHospital: true,
          affiliatedProfessional: true,
        },
      }),
      prisma.healthcarePaymentRecord.count({ where }),
    ]);

    // Format results
    const formattedPayments: PaymentListItem[] = payments.map((payment) => ({
      id: payment.id,
      recipientName: payment.recipientName || "Unknown",
      recipientType: payment.recipientType || "Unknown",
