    const timer = setTimeout(() => {
      if (query.trim().length > 0) {
        performSearch(query);
      } else {
        setResults([]);
        setTotal(0);
      }
    }, 300); // 300ms debounce

    return () => clearTimeout(timer);
  }, [entityType, riskLevel, state]);

