  signal: FraudSignalDefinition,
  dryRun: boolean,
  verbose: boolean,
): Promise<number> {
  if (verbose) {
    console.log(`\n🔍 Detecting signal: ${signal.id}`);
    console.log(`   Name: ${signal.name}`);
    console.log(`   Severity: ${signal.severity} (weight: ${signal.weight})`);
  }

  try {
