      entityType: snapshot.entityType,
      score: snapshot.score,
      riskLevel: snapshot.riskLevel as "low" | "medium" | "high" | "critical",
      signalCount: snapshot.signalCount,
      topSignals: snapshot.topSignals || [],
    };
  }

  // No snapshot exists - return null or trigger detection
  return null;
}

