async function fetchWithRetry<T>(url: string, retries = 3): Promise<T> {
  for (let attempt = 1; attempt <= retries; attempt++) {
    try {
      const response = await fetch(url, {
        headers: {
          "User-Agent": "TrackFraud/1.0",
          Accept: "application/json",
        },
      });

      if (!response.ok) {
