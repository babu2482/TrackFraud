      );

      const results = await Promise.allSettled(createPromises);
      createdCount += results.filter((r) => r.status === "fulfilled").length;

      if (verbose && (i + batchSize) % 500 === 0) {
        console.log(
          `   → Created ${createdCount}/${affectedEntityIds.length} events...`,
