                explanation: `Top signals: ${score.topSignals.map((s) => s.name).join(", ")}`,
              },
            });
          }
        }),
      );
    }

    if (verbose) {
      console.log(`   ✓ Created/updated ${scores.length} snapshots`);
    }
  }

  // Sort by score descending and return top results
  scores.sort((a, b) => b.score - a.score);
  return scores;
}

