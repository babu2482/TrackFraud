/**
 * Ingest parsed EPA facility records into the database.
 */
async function ingestFacilities(
  facilities: ParsedEnforcementAction[],
  maxRows: number | null = null,
): Promise<{ inserted: number; updated: number }> {
  const sourceSystemId = await getSourceSystemId();

  console.log(`\nProcessing ${facilities.length} facility records...`);

  if (maxRows && facilities.length > maxRows) {
    console.log(`Limiting to first ${maxRows} records for testing`);
    // Slice creates a new array, leaving original intact
    const limited = [...facilities].slice(0, maxRows);

    let inserted = 0;
    let updated = 0;

    for (const facility of limited) {
      try {
        await prisma.ePAEnforcementAction.upsert({
          where: { actionId: facility.facilityId },
          update: {
            facilityName: facility.facilityName,
          },
          create: {
            actionId: facility.facilityId,
            sourceSystemId,
            facilityName: facility.facilityName || "Unknown",
            violationType: facility.industryType || "General Industry",
            statute: "Multiple Statutes (EPA)",
            status: facility.facilityopstatus || "Active",
          },
        });

        updated++;
      } catch (error) {
        console.error(
          `Error processing ${facility.facilityId}:`,
          error instanceof Error ? error.message : String(error),
        );
        // Continue with other records - don't fail the entire batch
      }
    }

    return { inserted, updated };
  }

  let totalInserted = 0;
  const batchSize = 1_000;

  for (let i = 0; i < facilities.length; i += batchSize) {
    const batch = facilities.slice(
      i,
      Math.min(i + batchSize, facilities.length),
    );

    await Promise.allSettled(
      batch.map(async (facility) => {
        try {
          await prisma.ePAEnforcementAction.upsert({
            where: { actionId: facility.facilityId },
            update: {
              facilityName: facility.facilityName,
            },
            create: {
              actionId: facility.facilityId,
              sourceSystemId,
              facilityName: facility.facilityName || "Unknown",
              violationType: facility.industryType || "General Industry",
              statute: "Multiple Statutes (EPA)",
              status: facility.facilityopstatus || "Active",
            },
          });

          totalInserted++;
        } catch (_error) {
          // Continue with other records - don't fail the entire batch
        }
      }),
    );

    const processed = Math.min(i + batchSize, facilities.length);

    // Report progress every 10K rows or at end
    if (processed % 10_000 === 0 || i >= facilities.length) {
      const percent = Math.round((processed / facilities.length) * 100);
      console.log(
        `Progress: ${percent}% (${processed}/${facilities.length}) processed`,
      );
    }

    // Small delay to avoid overwhelming the database for large datasets
    if (i % 5_000 === 0 && i > 0) {
      await new Promise((resolve) => setTimeout(resolve, 20));
    }
  }

  return { inserted: totalInserted, updated: 0 };
}

/**
 * Update the SourceSystem record with latest sync status.
 */
async function updateSourceSystemStatus(
  sourceSystemId: string,
  stats: { inserted: number; updated: number },
): Promise<void> {
  await prisma.sourceSystem.update({
    where: { id: sourceSystemId },
    data: {
      lastAttemptedSyncAt: new Date(),
      // Consider it successful if we have records (even with some errors)
      lastSuccessfulSyncAt: stats.inserted > 0 ? new Date() : null,
    },
  });

  await prisma.ingestionRun.create({
    data: {
      sourceSystemId,
      runType: "full",
      status: stats.inserted > 0 ? "completed" : "failed",
      rowsRead: BigInt(stats.inserted + stats.updated),
      rowsInserted: BigInt(stats.inserted),
      rowsUpdated: BigInt(stats.updated),
    },
  });

  console.log("Source system status updated.");
}

