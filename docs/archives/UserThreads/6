            return;
          }
        }

        // Handle errors for non-redirect status codes
        const statusCode = response.statusCode ?? -1;
        if (statusCode < 200 || statusCode >= 300) {
          reject(new Error(`HTTP ${statusCode}: ${response.statusMessage}`));
          return;
        }

        console.log("Saving to file...");
        const writer = createWriteStream(destPath);

        response.pipe(writer);

        let downloadedBytes = 0;
        response.on("data", (chunk: Buffer) => {
          downloadedBytes += chunk.length;
        });

        writer.on("finish", () => {
          console.log(
            `Download complete: ${(downloadedBytes / 1024 / 1024).toFixed(2)} MB`,
          );
          resolve();
        });

        writer.on("error", (err) => reject(err));
      },
    );

    request.on("timeout", () => {
      console.warn(`Timeout downloading from ${url}, destroying connection...`);
      request.destroy(new Error("Request timeout"));
    });

    request.on("error", (err: unknown) => {
      const message = err instanceof Error ? err.message : String(err);
