# ============================================
# TrackFraud - .gitignore
# ============================================

# ============================================
# Dependencies
# ============================================
node_modules/
.pnp
.pnp.js

# ============================================
# Environment Variables (NEVER COMMIT)
# ============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.bak
*.env.bak

# Keep .env.example as reference
!.env.example

# ============================================
# Build Outputs
# ============================================
.next/
out/
build/
dist/
.cache/

# ============================================
# Database Files
# ============================================
prisma/generated/
prisma/dev.db
*.sqlite
*.sqlite3
*.db
*.sql.backup
database_backup_*.sql
prisma/migrations/.migration_lock.lock

# ============================================
# Data & Storage
# ============================================
!data/*.example.csv
data/consumer/
data/corporate/
data/government/
data/healthcare/
data/hhs-oig/
data/irs/
data/political/
data/treasury/
data/raw/
data/cache/
data/temp/
storage/
downloads/
*.csv.raw
*.xml.raw
*.json.raw

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ============================================
# Testing
# ============================================
coverage/
.nyc_output/
*.lcov
vitest-coverage/
playwright-report/
test-results/
.playwright-mcp/

# ============================================
# Runtime Artifacts
# ============================================
.execution-progress.json
congress-ingest-output.log

# ============================================
# IDE & Editor Configs
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# OS Files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================
# Docker & Container Data
# ============================================
postgres_data/
meilisearch_data/
redis_data/
.docker/

# ============================================
# Temporary Files
# ============================================
tmp/
temp/
*.tmp
*.temp

# ============================================
# TypeScript Cache
# ============================================
*.tsbuildinfo

# ============================================
# Archives (large files not for VCS)
# ============================================
archives/

# ============================================
# Misc
# ============================================
screenshots/
exports/
*.bak
*.backup
*.ts.backup

# ============================================
# Secrets & Keys (NEVER COMMIT)
# ============================================
*.pem
*.key
*.crt
secrets/
credentials.json
service-account-key.json

# ============================================
# Performance & Profiling
# ============================================
*.heapsnapshot
*.cpuprofile
*.profile

# ============================================
# Linting & Formatting Cache
# ============================================
.eslintcache
.stylelintcache
