generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bill {
  id             Int           @id @default(autoincrement())
  sourceSystemId String?
  congressNumber Int?
  billNumber     String
  billType       String?
  title          String
  summary        String?
  introducedDate DateTime?
  status         String?
  sourceUrl      String?
  externalId     String?
  createdAt      DateTime      @default(now())
  SourceSystem   SourceSystem? @relation(fields: [sourceSystemId], references: [id])
  BillSponsor    BillSponsor[]
  BillVote       BillVote[]

  @@index([congressNumber])
  @@index([status])
}

model BillSponsor {
  id             Int           @id @default(autoincrement())
  sourceSystemId String?
  billId         Int
  party          String?
  state          String?
  createdAt      DateTime      @default(now())
  bioguideId     String
  name           String
  sponsorType    String        @default("cosponsor")
  sponsoredDate  DateTime?
  updatedAt      DateTime      @updatedAt
  Bill           Bill          @relation(fields: [billId], references: [id])
  SourceSystem   SourceSystem? @relation(fields: [sourceSystemId], references: [id])

  @@unique([billId, bioguideId])
  @@index([billId])
  @@index([bioguideId])
}

model BillVote {
  id             Int           @id @default(autoincrement())
  sourceSystemId String?
  billId         Int
  voteType       String?
  voteDate       DateTime?
  result         String?
  yeas           Int           @default(0)
  nays           Int           @default(0)
  sourceUrl      String?
  createdAt      DateTime      @default(now())
  chamberCode    String?
  congressNumber Int?
  externalId     String?       @unique
  notVoting      Int           @default(0)
  present        Int           @default(0)
  questionText   String?
  rollcallNumber String?
  submittedDate  DateTime?
  updatedAt      DateTime      @updatedAt
  Bill           Bill          @relation(fields: [billId], references: [id])
  SourceSystem   SourceSystem? @relation(fields: [sourceSystemId], references: [id])

  @@index([billId])
  @@index([chamberCode])
  @@index([congressNumber])
}

model CMSProgramSafeguardExclusion {
  id               String       @id @default(uuid())
  sourceSystemId   String
  cmsId            String       @unique
  lastName         String?
  firstName        String?
  organizationName String?
  exclusionType    String
  effectiveDate    DateTime
  terminationDate  DateTime?
  state            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  SourceSystem     SourceSystem @relation(fields: [sourceSystemId], references: [id])

  @@index([effectiveDate])
  @@index([lastName, firstName])
}

model CabinetMember {
  id               Int           @id @default(autoincrement())
  sourceSystemId   String?
  presidentId      Int
  position         String
  firstName        String?
  lastName         String
  startDate        DateTime?
  endDate          DateTime?
  bio              String?
  priorPosition    String?
  confirmed        Boolean       @default(false)
  confirmationDate DateTime?
  createdAt        DateTime      @default(now())
  President        President     @relation(fields: [presidentId], references: [id])
  SourceSystem     SourceSystem? @relation(fields: [sourceSystemId], references: [id])

  @@index([position])
  @@index([presidentId])
}

model CanonicalEntity {
  id                                                                                 String                            @id @default(uuid())
  categoryId                                                                         String
  displayName                                                                        String
  normalizedName                                                                     String
  entityType                                                                         String
  status                                                                             String                            @default("active")
  primaryJurisdiction                                                                String?
  stateCode                                                                          String?
  countryCode                                                                        String?
  summary                                                                            String?
  homepageUrl                                                                        String?
  latestSourceUpdatedAt                                                              DateTime?
  firstSeenAt                                                                        DateTime                          @default(now())
  lastSeenAt                                                                         DateTime                          @default(now())
  createdAt                                                                          DateTime                          @default(now())
  updatedAt                                                                          DateTime                          @default(now()) @updatedAt
  politicalCandidateProfileId                                                        String?
  FraudCategory                                                                      FraudCategory                     @relation(fields: [categoryId], references: [id])
  PoliticalCandidateProfile                                                          PoliticalCandidateProfile?        @relation(fields: [politicalCandidateProfileId], references: [id])
  CharityAutomaticRevocationRecord                                                   CharityAutomaticRevocationRecord?
  CharityBusinessMasterRecord                                                        CharityBusinessMasterRecord?
  CharityEpostcard990NRecord                                                         CharityEpostcard990NRecord[]
  CharityFiling                                                                      CharityFiling[]
  CharityProfile                                                                     CharityProfile?
  CharityPublication78Record                                                         CharityPublication78Record?
  ConsumerCompanySummary                                                             ConsumerCompanySummary?
  ConsumerComplaintRecord                                                            ConsumerComplaintRecord[]
  CorporateCompanyFactsSnapshot                                                      CorporateCompanyFactsSnapshot?
  CorporateCompanyProfile                                                            CorporateCompanyProfile?
  CorporateFilingRecord                                                              CorporateFilingRecord[]
  EntityAlias                                                                        EntityAlias[]
  EntityIdentifier                                                                   EntityIdentifier[]
  FraudSignalEvent                                                                   FraudSignalEvent[]
  FraudSnapshot                                                                      FraudSnapshot[]
  GovernmentAwardRecord                                                              GovernmentAwardRecord[]
  HealthcarePaymentRecord_HealthcarePaymentRecord_companyEntityIdToCanonicalEntity   HealthcarePaymentRecord[]         @relation("HealthcarePaymentRecord_companyEntityIdToCanonicalEntity")
  HealthcarePaymentRecord_HealthcarePaymentRecord_recipientEntityIdToCanonicalEntity HealthcarePaymentRecord[]         @relation("HealthcarePaymentRecord_recipientEntityIdToCanonicalEntity")
  HealthcareRecipientProfile                                                         HealthcareRecipientProfile?
  PoliticalCommitteeProfile                                                          PoliticalCommitteeProfile?
  PoliticalCycleSummary                                                              PoliticalCycleSummary[]
  PoliticianClaim                                                                    PoliticianClaim[]
  PresidentialAction                                                                 PresidentialAction[]
  RawArtifact                                                                        RawArtifact[]

  @@index([categoryId, normalizedName])
  @@index([entityType])
  @@index([lastSeenAt])
}

model CharityAutomaticRevocationRecord {
  id                            String           @id @default(uuid())
  ein                           String           @unique
  entityId                      String?          @unique
  sourceSystemId                String
  organizationName              String
  sortName                      String?
  address                       String?
  city                          String?
  state                         String?
  zipCode                       String?
  countryCode                   String?
  subsectionCodeRaw             String?
  revocationDateRaw             String?
  revocationDate                DateTime?
  revocationPostingDateRaw      String?
  revocationPostingDate         DateTime?
  exemptionReinstatementDateRaw String?
  exemptionReinstatementDate    DateTime?
  sourcePublishedAt             DateTime?
  createdAt                     DateTime         @default(now())
  updatedAt                     DateTime         @updatedAt
  CanonicalEntity               CanonicalEntity? @relation(fields: [entityId], references: [id])
  SourceSystem                  SourceSystem     @relation(fields: [sourceSystemId], references: [id])

  @@index([revocationDate])
  @@index([sourceSystemId, revocationPostingDate])
  @@index([state, city])
  @@index([subsectionCodeRaw])
}

model CharityBusinessMasterRecord {
  id                      String          @id @default(uuid())
  entityId                String          @unique
  sourceSystemId          String
  sourceFileCode          String?
  sourceFileUrl           String?
  careOfName              String?
  street                  String?
  city                    String?
  state                   String?
  zip                     String?
  groupCode               String?
  subsectionCodeRaw       String?
  affiliationCode         String?
  classificationCode      String?
  rulingDateRaw           String?
  deductibilityCode       String?
  foundationCodeRaw       String?
  activityCode            String?
  organizationCode        String?
  statusCode              String?
  taxPeriodRaw            String?
  assetCode               String?
  incomeCode              String?
  assetAmount             BigInt?
  incomeAmount            BigInt?
  revenueAmount           BigInt?
  filingRequirementCode   String?
  pfFilingRequirementCode String?
  accountingPeriod        String?
  nteeCode                String?
  sortName                String?
  sourcePublishedAt       DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  CanonicalEntity         CanonicalEntity @relation(fields: [entityId], references: [id])
  SourceSystem            SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([nteeCode])
  @@index([sourceSystemId, sourcePublishedAt])
  @@index([state, city])
  @@index([subsectionCodeRaw])
}

model CharityEpostcard990NRecord {
  id                    String           @id @default(uuid())
  ein                   String
  entityId              String?
  sourceSystemId        String
  taxYear               Int?
  organizationName      String
  grossReceiptsUnder25K Boolean?
  principalOfficerName  String?
  websiteUrl            String?
  terminated            Boolean?
  taxPeriodBeginDate    DateTime?
  taxPeriodEndDate      DateTime?
  sourcePublishedAt     DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  CanonicalEntity       CanonicalEntity? @relation(fields: [entityId], references: [id])
  SourceSystem          SourceSystem     @relation(fields: [sourceSystemId], references: [id])

  @@unique([ein, taxYear])
  @@index([entityId])
  @@index([sourceSystemId])
  @@index([taxYear])
  @@index([terminated])
}

model CharityFiling {
  id                    String          @id @default(uuid())
  entityId              String
  sourceSystemId        String?
  sourceFilingKey       String?         @unique
  taxPeriod             Int
  filingYear            Int
  formType              Int?
  isLatest              Boolean         @default(false)
  sourceUpdatedAt       DateTime?
  totalRevenue          BigInt?
  contributionsRevenue  BigInt?
  programServiceRevenue BigInt?
  otherRevenue          BigInt?
  totalExpenses         BigInt?
  programExpenses       BigInt?
  managementExpenses    BigInt?
  fundraisingExpenses   BigInt?
  programExpenseRatio   Float?
  overheadRatio         Float?
  fundraisingEfficiency Float?
  compensationPct       Float?
  totalAssets           BigInt?
  totalLiabilities      BigInt?
  pdfUrl                String?
  rawSourceUrl          String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  CanonicalEntity       CanonicalEntity @relation(fields: [entityId], references: [id])
  SourceSystem          SourceSystem?   @relation(fields: [sourceSystemId], references: [id])

  @@index([entityId, isLatest])
  @@index([entityId, taxPeriod])
  @@index([filingYear])
  @@index([sourceSystemId])
}

model CharityFiling990Index {
  id               String       @id @default(uuid())
  objectId         String       @unique
  returnId         String?
  filingType       String?
  ein              String
  taxpayerName     String?
  returnType       String?
  taxPeriod        String?
  subDate          String?
  dln              String?
  lastUpdated      String?
  filingYear       Int?
  sourceSystemId   String
  xmlBatchId       String?
  archiveFileName  String?
  archiveUrl       String?
  archiveEntryPath String?
  xmlUrl           String?
  xmlFetchStatus   String       @default("pending")
  xmlFetchedAt     DateTime?
  parsedAt         DateTime?
  charityFilingId  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  SourceSystem     SourceSystem @relation(fields: [sourceSystemId], references: [id])

  @@index([archiveFileName])
  @@index([ein])
  @@index([filingYear, archiveFileName])
  @@index([filingYear])
  @@index([sourceSystemId])
  @@index([xmlBatchId])
  @@index([xmlFetchStatus])
}

model CharityProfile {
  id              String          @id @default(uuid())
  entityId        String          @unique
  ein             String          @unique
  subName         String?
  address         String?
  city            String?
  state           String?
  zipcode         String?
  subsectionCode  Int?
  foundationCode  Int?
  nteeCode        String?
  guidestarUrl    String?
  nccsUrl         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  CanonicalEntity CanonicalEntity @relation(fields: [entityId], references: [id])

  @@index([nteeCode])
  @@index([state, city])
  @@index([subsectionCode])
}

model CharityPublication78Record {
  id                String           @id @default(uuid())
  ein               String           @unique
  entityId          String?          @unique
  sourceSystemId    String
  organizationName  String
  city              String?
  state             String?
  countryCode       String?
  deductibilityCode String?
  sourcePublishedAt DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  CanonicalEntity   CanonicalEntity? @relation(fields: [entityId], references: [id])
  SourceSystem      SourceSystem     @relation(fields: [sourceSystemId], references: [id])

  @@index([deductibilityCode])
  @@index([sourceSystemId])
  @@index([state])
}

model ConsumerCompanySummary {
  id                String          @id @default(uuid())
  sourceSystemId    String
  entityId          String          @unique
  totalComplaints   Int             @default(0)
  withRelief        Int             @default(0)
  withoutRelief     Int             @default(0)
  disputedCount     Int             @default(0)
  untimelyCount     Int             @default(0)
  topProduct        String?
  topProductCount   Int?
  latestComplaintAt DateTime?
  sourcePublishedAt DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  CanonicalEntity   CanonicalEntity @relation(fields: [entityId], references: [id])
  SourceSystem      SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([latestComplaintAt])
  @@index([sourceSystemId, sourcePublishedAt])
  @@index([totalComplaints])
}

model ConsumerComplaintRecord {
  id                        String          @id @default(uuid())
  sourceSystemId            String
  entityId                  String
  complaintId               String          @unique
  normalizedCompany         String
  dateReceived              DateTime?
  product                   String?
  subProduct                String?
  issue                     String?
  subIssue                  String?
  companyResponse           String?
  timely                    String?
  consumerDisputed          String?
  complaintWhatHappened     String?
  dateSentToCompany         DateTime?
  companyPublicResponse     String?
  companyResponseToConsumer String?
  submittedVia              String?
  state                     String?
  zipCode                   String?
  tags                      String?
  sourceRecordUpdatedAt     DateTime?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  CanonicalEntity           CanonicalEntity @relation(fields: [entityId], references: [id])
  SourceSystem              SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([entityId, dateReceived])
  @@index([normalizedCompany])
  @@index([product])
  @@index([sourceSystemId, sourceRecordUpdatedAt])
  @@index([state])
}

model CorporateCompanyFactsSnapshot {
  id              String          @id @default(uuid())
  sourceSystemId  String
  entityId        String          @unique
  factsJson       Json
  sourceUpdatedAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  CanonicalEntity CanonicalEntity @relation(fields: [entityId], references: [id])
  SourceSystem    SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([sourceSystemId, sourceUpdatedAt])
}

model CorporateCompanyProfile {
  id                   String          @id @default(uuid())
  sourceSystemId       String
  entityId             String          @unique
  cik                  String          @unique
  entityType           String?
  sic                  String?
  sicDescription       String?
  tickers              String[]
  exchanges            String[]
  stateOfIncorporation String?
  fiscalYearEnd        String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  CanonicalEntity      CanonicalEntity @relation(fields: [entityId], references: [id])
  SourceSystem         SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([sic])
  @@index([sourceSystemId])
  @@index([stateOfIncorporation])
}

model CorporateFilingRecord {
  id                    String          @id @default(uuid())
  sourceSystemId        String
  entityId              String
  accessionNumber       String          @unique
  filingDate            DateTime?
  reportDate            DateTime?
  form                  String
  primaryDocument       String?
  primaryDocDescription String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  CanonicalEntity       CanonicalEntity @relation(fields: [entityId], references: [id])
  SourceSystem          SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([entityId, filingDate])
  @@index([form])
  @@index([sourceSystemId])
}

model DOJCivilFraud {
  id             String       @id @default(uuid())
  sourceSystemId String
  caseNumber     String?
  dateAnnounced  DateTime
  defendantName  String
  recoveryAmount Float?
  falseClaimsAct Boolean
  summary        String?
  url            String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  SourceSystem   SourceSystem @relation(fields: [sourceSystemId], references: [id])

  @@index([dateAnnounced])
  @@index([defendantName])
}

model EPAEnforcementAction {
  id             String       @id @default(uuid())
  sourceSystemId String
  actionId       String       @unique
  facilityName   String?
  violationType  String
  statute        String
  penaltyAmount  Float?
  actionDate     DateTime
  resolutionDate DateTime?
  status         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  SourceSystem   SourceSystem @relation(fields: [sourceSystemId], references: [id])

  @@index([actionDate])
  @@index([statute])
}

model EntityAlias {
  id              String          @id @default(uuid())
  entityId        String
  sourceSystemId  String?
  alias           String
  normalizedAlias String
  aliasType       String          @default("alternate_name")
  isPrimary       Boolean         @default(false)
  confidence      Float?
  observedAt      DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  CanonicalEntity CanonicalEntity @relation(fields: [entityId], references: [id])
  SourceSystem    SourceSystem?   @relation(fields: [sourceSystemId], references: [id])

  @@unique([entityId, normalizedAlias, aliasType])
  @@index([normalizedAlias])
  @@index([sourceSystemId])
}

model EntityIdentifier {
  id              String          @id @default(uuid())
  entityId        String
  sourceSystemId  String?
  identifierType  String
  identifierValue String
  isPrimary       Boolean         @default(false)
  confidence      Float?
  observedAt      DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  CanonicalEntity CanonicalEntity @relation(fields: [entityId], references: [id])
  SourceSystem    SourceSystem?   @relation(fields: [sourceSystemId], references: [id])

  @@unique([entityId, identifierType, identifierValue])
  @@index([identifierType, identifierValue])
  @@index([sourceSystemId])
}

model FDAWarningLetter {
  id               String       @id @default(uuid())
  sourceSystemId   String
  recipientName    String
  recipientAddress String?
  issueDate        DateTime
  violationTypes   String[]
  productCategory  String
  summary          String?
  url              String       @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  SourceSystem     SourceSystem @relation(fields: [sourceSystemId], references: [id])

  @@index([issueDate])
  @@index([recipientName])
}

model FINRADisclosure {
  id             String       @id @default(uuid())
