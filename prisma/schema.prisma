  brokerOrFirm   String
  entityType     String
  disclosureType String
  status         String
  date           DateTime?
  description    String?
  amount         Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  SourceSystem   SourceSystem @relation(fields: [sourceSystemId], references: [id])

  @@index([brokerOrFirm])
  @@index([entityType])
}

model FTCConsumerProtectionAction {
  id               String       @id @default(uuid())
  sourceSystemId   String
  docketNumber     String?
  date             DateTime
  respondentName   String
  actionType       String
  summary          String?
  settlementAmount Float?
  url              String       @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  SourceSystem     SourceSystem @relation(fields: [sourceSystemId], references: [id])

  @@index([date])
  @@index([respondentName])
}

model FTCDataBreach {
  id               String       @id @default(uuid())
  sourceSystemId   String
  company          String
  industry         String?
  breachDate       DateTime?
  notificationDate DateTime
  recordsAffected  Int?
  dataTypesExposed String[]
  settlementAmount Float?
  url              String       @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  SourceSystem     SourceSystem @relation(fields: [sourceSystemId], references: [id])

  @@index([company])
  @@index([notificationDate])
}

model FactCheck {
  id              Int             @id @default(autoincrement())
  sourceSystemId  String?
  claimId         Int
  rating          String?
  conclusion      String?
  sourceName      String?
  sourceUrl       String?
  publishedDate   DateTime?
  createdAt       DateTime        @default(now())
  PoliticianClaim PoliticianClaim @relation(fields: [claimId], references: [id])
  SourceSystem    SourceSystem?   @relation(fields: [sourceSystemId], references: [id])

  @@index([claimId])
}

model FederalRegisterDocument {
  id              String       @id @default(uuid())
  sourceSystemId  String
  externalId      String       @unique
  title           String
  documentType    String
  agencies        String?
  documentNumber  String
  publicationDate DateTime
