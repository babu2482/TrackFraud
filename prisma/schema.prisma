  pdfUrl          String?
  commentsUrl     String?
  docketIds       String?
  cfdaNumbers     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  SourceSystem    SourceSystem @relation(fields: [sourceSystemId], references: [id])

  @@index([agencies])
  @@index([documentType])
  @@index([publicationDate])
  @@index([sourceSystemId])
}

model FraudCategory {
  id              String            @id @default(uuid())
  name            String
  slug            String            @unique
  description     String
  status          String            @default("coming_soon")
  iconName        String?
  sortOrder       Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  CanonicalEntity CanonicalEntity[]
  SourceSystem    SourceSystem[]
  Subscriber      Subscriber[]
  Tip             Tip[]
}

model FraudSignalEvent {
  id                 String          @id @default(uuid())
  entityId           String
  sourceSystemId     String?
  signalKey          String
  signalLabel        String
  severity           String
  detail             String
  measuredValue      Float?
  measuredText       String?
  thresholdValue     Float?
  scoreImpact        Int?
  sourceRecordId     String?
  methodologyVersion String          @default("v1")
  status             String          @default("active")
  observedAt         DateTime        @default(now())
  resolvedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  CanonicalEntity    CanonicalEntity @relation(fields: [entityId], references: [id])
  SourceSystem       SourceSystem?   @relation(fields: [sourceSystemId], references: [id])

  @@unique([entityId, signalKey, observedAt])
  @@index([entityId, status, observedAt])
  @@index([signalKey, observedAt])
  @@index([sourceSystemId])
}

model FraudSnapshot {
  id                 String          @id @default(uuid())
  entityId           String
  score              Int
  level              String
  bandLabel          String?
  baseScore          Int?
  corroborationCount Int             @default(0)
  activeSignalCount  Int             @default(0)
  explanation        String?
  methodologyVersion String          @default("v1")
  sourceFreshnessAt  DateTime?
  isCurrent          Boolean         @default(true)
  computedAt         DateTime        @default(now())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  CanonicalEntity    CanonicalEntity @relation(fields: [entityId], references: [id])

  @@index([computedAt])
  @@index([entityId, isCurrent])
  @@index([score])
}

model GovernmentAwardRecord {
  id                          String           @id @default(uuid())
  sourceSystemId              String
  generatedInternalId         String           @unique
  internalId                  Int?
  generatedUniqueAwardId      String?
  awardId                     String?
  recipientEntityId           String?
  recipientName               String?
  awardingAgencyName          String?
  fundingAgencyName           String?
  awardAmount                 Float?
  totalOutlays                Float?
  totalObligation             Float?
  baseAndAllOptionsValue      Float?
  description                 String?
  startDate                   DateTime?
  endDate                     DateTime?
  awardType                   String?
  typeDescription             String?
  defCodes                    String[]
  covidSpending               Boolean?
  recipientUei                String?
  recipientBusinessCategories String[]
  placeOfPerformanceCity      String?
  placeOfPerformanceStateCode String?
  placeOfPerformanceCountry   String?
  naics                       String?
  naicsDescription            String?
  pscCode                     String?
  contractPricingDescription  String?
  extentCompetedDescription   String?
  numberOfOffersReceived      Int?
  sourceRecordUpdatedAt       DateTime?
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
  CanonicalEntity             CanonicalEntity? @relation(fields: [recipientEntityId], references: [id])
  SourceSystem                SourceSystem     @relation(fields: [sourceSystemId], references: [id])

  @@index([awardAmount])
  @@index([awardId])
  @@index([awardingAgencyName])
  @@index([recipientEntityId])
  @@index([recipientName])
  @@index([sourceSystemId, sourceRecordUpdatedAt])
}

model HHSExclusion {
  id                 String       @id @default(uuid())
  sourceSystemId     String
  uiEProviderId      String       @unique
  lastName           String
  firstName          String?
  middleName         String?
  organizationName   String?
  exclusionReasons   String[]
  programInvolvement String[]
  effectiveDate      DateTime
  terminationDate    DateTime?
  stateLicenseInfo   Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  SourceSystem       SourceSystem @relation(fields: [sourceSystemId], references: [id])

  @@index([effectiveDate])
  @@index([lastName, firstName])
}

model HealthcarePaymentRecord {
  id                                                                         String          @id @default(uuid())
  sourceSystemId                                                             String
  recordId                                                                   String          @unique
  paymentType                                                                String
  programYear                                                                Int?
