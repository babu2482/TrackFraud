generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FraudCategory {
  id            String            @id
  name          String
  slug          String            @unique
  description   String
  status        String            @default("coming_soon")
  iconName      String?
  sortOrder     Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  entities      CanonicalEntity[]
  sourceSystems SourceSystem[]
  subscribers   Subscriber[]
  tips          Tip[]
}

model Tip {
  id             String        @id @default(cuid())
  categoryId     String
  entityName     String
  entityId       String?
  title          String
  description    String
  evidence       String?
  severity       String        @default("unknown")
  status         String        @default("pending")
  submitterEmail String?
  submitterName  String?
  ipHash         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  category       FraudCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
}

model Subscriber {
  id         String        @id @default(cuid())
  email      String
  categoryId String
  createdAt  DateTime      @default(now())
  category   FraudCategory @relation(fields: [categoryId], references: [id])

  @@unique([email, categoryId])
  @@index([categoryId])
}

model SourceSystem {
  id                            String                             @id
  categoryId                    String
  name                          String
  slug                          String                             @unique
  description                   String?
  ingestionMode                 String                             @default("api")
  baseUrl                       String?
  refreshCadence                String?
  freshnessSlaHours             Int?
  supportsIncremental           Boolean                            @default(false)
  lastAttemptedSyncAt           DateTime?
  lastSuccessfulSyncAt          DateTime?
  lastError                     String?
  createdAt                     DateTime                           @default(now())
  updatedAt                     DateTime                           @default(now())
  bills                         Bill[]
  billSponsors                  BillSponsor[]
  billVotes                     BillVote[]
  cmsProgramSafeguardExclusions CMSProgramSafeguardExclusion[]
  cabinetMembers                CabinetMember[]
  charityAutomaticRevocations   CharityAutomaticRevocationRecord[]
  charityBusinessMasterRecords  CharityBusinessMasterRecord[]
  charityEpostcard990NRecords   CharityEpostcard990NRecord[]
  charityFilings                CharityFiling[]
  charityFiling990Indexes       CharityFiling990Index[]
  charityPublication78Records   CharityPublication78Record[]
  consumerCompanySummaries      ConsumerCompanySummary[]
  consumerComplaintRecords      ConsumerComplaintRecord[]
  corporateCompanyFacts         CorporateCompanyFactsSnapshot[]
  corporateCompanyProfiles      CorporateCompanyProfile[]
  corporateFilingRecords        CorporateFilingRecord[]
  dojCivilFraud                 DOJCivilFraud[]
  epaEnforcementActions         EPAEnforcementAction[]
  aliases                       EntityAlias[]
  identifiers                   EntityIdentifier[]
  fdaWarningLetters             FDAWarningLetter[]
  finraDisclosures              FINRADisclosure[]
  ftcConsumerProtectionActions  FTCConsumerProtectionAction[]
  ftcDataBreaches               FTCDataBreach[]
  factChecks                    FactCheck[]
  federalRegisterDocuments      FederalRegisterDocument[]
  fraudSignals                  FraudSignalEvent[]
  governmentAwardRecords        GovernmentAwardRecord[]
  hhsExclusions                 HHSExclusion[]
  healthcarePaymentRecords      HealthcarePaymentRecord[]
  healthcareRecipientProfiles   HealthcareRecipientProfile[]
  ingestionRuns                 IngestionRun[]
  memberVotes                   MemberVote[]
  ofacSanctions                 OFACSanction[]
  politicalCandidateProfiles    PoliticalCandidateProfile[]
  politicalCommitteeProfiles    PoliticalCommitteeProfile[]
  politicalCycleSummaries       PoliticalCycleSummary[]
  politicianClaims              PoliticianClaim[]
  politicianCommittees          PoliticianCommittee[]
  presidents                    President[]
  presidentialActions           PresidentialAction[]
  propublicaNonprofits          ProPublicaNonprofit[]
  rawArtifacts                  RawArtifact[]
  samExclusions                 SAMExclusion[]
  secEnforcementActions         SECEnforcementAction[]
  category                      FraudCategory                      @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([lastSuccessfulSyncAt])
}

model IngestionRun {
  id              String        @id @default(cuid())
  sourceSystemId  String
  runType         String        @default("incremental")
  status          String        @default("pending")
  cursor          String?
  windowStart     DateTime?
  windowEnd       DateTime?
  rowsRead        Int           @default(0)
  rowsInserted    Int           @default(0)
  rowsUpdated     Int           @default(0)
  rowsSkipped     Int           @default(0)
  rowsFailed      Int           @default(0)
  bytesDownloaded BigInt        @default(0)
  checksum        String?
  errorSummary    String?
  triggeredBy     String?
  startedAt       DateTime      @default(now())
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sourceSystem    SourceSystem  @relation(fields: [sourceSystemId], references: [id])
  rawArtifacts    RawArtifact[]

  @@index([sourceSystemId, startedAt])
  @@index([status, startedAt])
}

model CanonicalEntity {
  id                          String                            @id @default(cuid())
  categoryId                  String
  displayName                 String
  normalizedName              String
  entityType                  String
  status                      String                            @default("active")
  primaryJurisdiction         String?
  stateCode                   String?
  countryCode                 String?
  summary                     String?
  homepageUrl                 String?
  latestSourceUpdatedAt       DateTime?
  firstSeenAt                 DateTime                          @default(now())
  lastSeenAt                  DateTime                          @default(now())
  createdAt                   DateTime                          @default(now())
  updatedAt                   DateTime                          @default(now())
  politicalCandidateProfileId String?
  category                    FraudCategory                     @relation(fields: [categoryId], references: [id])
  politicalCandidateProfile   PoliticalCandidateProfile?        @relation(fields: [politicalCandidateProfileId], references: [id])
  charityAutomaticRevocation  CharityAutomaticRevocationRecord?
  charityBusinessMasterRecord CharityBusinessMasterRecord?
  charityEpostcard990NRecords CharityEpostcard990NRecord[]
  charityFilings              CharityFiling[]
  charityProfile              CharityProfile?
  charityPublication78Record  CharityPublication78Record?
  consumerCompanySummary      ConsumerCompanySummary?
  consumerComplaintRecords    ConsumerComplaintRecord[]
  corporateCompanyFacts       CorporateCompanyFactsSnapshot?
  corporateCompanyProfile     CorporateCompanyProfile?
  corporateFilings            CorporateFilingRecord[]
  aliases                     EntityAlias[]
  identifiers                 EntityIdentifier[]
  fraudSignals                FraudSignalEvent[]
  fraudSnapshots              FraudSnapshot[]
  governmentAwardRecipients   GovernmentAwardRecord[]           @relation("GovernmentAwardRecipient")
  healthcareCompanyPayments   HealthcarePaymentRecord[]         @relation("HealthcareCompanyPayments")
  healthcareReceivedPayments  HealthcarePaymentRecord[]         @relation("HealthcareRecipientPayments")
  healthcareRecipientProfile  HealthcareRecipientProfile?
  politicalCommitteeProfile   PoliticalCommitteeProfile?
  politicalCycleSummaries     PoliticalCycleSummary[]
  politicianClaims            PoliticianClaim[]
  presidentialActions         PresidentialAction[]
  rawArtifacts                RawArtifact[]

  @@index([categoryId, normalizedName])
  @@index([entityType])
  @@index([lastSeenAt])
}

model CharityProfile {
  id             String          @id @default(cuid())
  entityId       String          @unique
  ein            String          @unique
  subName        String?
  address        String?
  city           String?
  state          String?
  zipcode        String?
  subsectionCode Int?
  foundationCode Int?
  nteeCode       String?
  guidestarUrl   String?
  nccsUrl        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  entity         CanonicalEntity @relation(fields: [entityId], references: [id])

  @@index([state, city])
  @@index([nteeCode])
  @@index([subsectionCode])
}

model CharityAutomaticRevocationRecord {
  id                            String           @id @default(cuid())
  ein                           String           @unique
  entityId                      String?          @unique
  sourceSystemId                String
  organizationName              String
  sortName                      String?
  address                       String?
  city                          String?
  state                         String?
  zipCode                       String?
  countryCode                   String?
  subsectionCodeRaw             String?
  revocationDateRaw             String?
  revocationDate                DateTime?
  revocationPostingDateRaw      String?
  revocationPostingDate         DateTime?
  exemptionReinstatementDateRaw String?
  exemptionReinstatementDate    DateTime?
  sourcePublishedAt             DateTime?
  createdAt                     DateTime         @default(now())
  updatedAt                     DateTime         @updatedAt
  entity                        CanonicalEntity? @relation(fields: [entityId], references: [id])
  sourceSystem                  SourceSystem     @relation(fields: [sourceSystemId], references: [id])

  @@index([sourceSystemId, revocationPostingDate])
  @@index([state, city])
  @@index([subsectionCodeRaw])
  @@index([revocationDate])
}

model CharityBusinessMasterRecord {
  id                      String          @id @default(cuid())
  entityId                String          @unique
  sourceSystemId          String
  sourceFileCode          String?
  sourceFileUrl           String?
  careOfName              String?
  street                  String?
  city                    String?
  state                   String?
  zip                     String?
  groupCode               String?
  subsectionCodeRaw       String?
  affiliationCode         String?
  classificationCode      String?
  rulingDateRaw           String?
  deductibilityCode       String?
  foundationCodeRaw       String?
  activityCode            String?
  organizationCode        String?
  statusCode              String?
  taxPeriodRaw            String?
  assetCode               String?
  incomeCode              String?
  filingRequirementCode   String?
  pfFilingRequirementCode String?
  accountingPeriod        String?
  assetAmount             BigInt?
  incomeAmount            BigInt?
  revenueAmount           BigInt?
  nteeCode                String?
  sortName                String?
  sourcePublishedAt       DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  entity                  CanonicalEntity @relation(fields: [entityId], references: [id])
  sourceSystem            SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([sourceSystemId, sourcePublishedAt])
  @@index([state, city])
  @@index([subsectionCodeRaw])
  @@index([nteeCode])
}

model CharityFiling {
  id                    String          @id @default(cuid())
  entityId              String
  sourceSystemId        String?
  sourceFilingKey       String?         @unique
  taxPeriod             Int
  filingYear            Int
  formType              Int?
  isLatest              Boolean         @default(false)
  sourceUpdatedAt       DateTime?
  totalRevenue          BigInt?
  contributionsRevenue  BigInt?
  programServiceRevenue BigInt?
  otherRevenue          BigInt?
  totalExpenses         BigInt?
  programExpenses       BigInt?
  managementExpenses    BigInt?
  fundraisingExpenses   BigInt?
  programExpenseRatio   Float?
  overheadRatio         Float?
  fundraisingEfficiency Float?
  compensationPct       Float?
  totalAssets           BigInt?
  totalLiabilities      BigInt?
  pdfUrl                String?
  rawSourceUrl          String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  entity                CanonicalEntity @relation(fields: [entityId], references: [id])
  sourceSystem          SourceSystem?   @relation(fields: [sourceSystemId], references: [id])

  @@index([entityId, isLatest])
  @@index([entityId, taxPeriod])
  @@index([filingYear])
  @@index([sourceSystemId])
}

model EntityIdentifier {
  id              String          @id @default(cuid())
  entityId        String
  sourceSystemId  String?
  identifierType  String
  identifierValue String
  isPrimary       Boolean         @default(false)
  confidence      Float?
  observedAt      DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  entity          CanonicalEntity @relation(fields: [entityId], references: [id])
  sourceSystem    SourceSystem?   @relation(fields: [sourceSystemId], references: [id])

  @@unique([entityId, identifierType, identifierValue])
  @@index([identifierType, identifierValue])
  @@index([sourceSystemId])
}

model EntityAlias {
  id              String          @id @default(cuid())
  entityId        String
  sourceSystemId  String?
  alias           String
  normalizedAlias String
  aliasType       String          @default("alternate_name")
  isPrimary       Boolean         @default(false)
  confidence      Float?
  observedAt      DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  entity          CanonicalEntity @relation(fields: [entityId], references: [id])
  sourceSystem    SourceSystem?   @relation(fields: [sourceSystemId], references: [id])

  @@unique([entityId, normalizedAlias, aliasType])
  @@index([normalizedAlias])
  @@index([sourceSystemId])
}

model FraudSignalEvent {
  id                 String          @id @default(cuid())
  entityId           String
  sourceSystemId     String?
  signalKey          String
  signalLabel        String
  severity           String
  detail             String
  measuredValue      Float?
  measuredText       String?
  thresholdValue     Float?
  scoreImpact        Int?
  sourceRecordId     String?
  methodologyVersion String          @default("v1")
  status             String          @default("active")
  observedAt         DateTime        @default(now())
  resolvedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  entity             CanonicalEntity @relation(fields: [entityId], references: [id])
  sourceSystem       SourceSystem?   @relation(fields: [sourceSystemId], references: [id])

  @@index([entityId, status, observedAt])
  @@index([signalKey, observedAt])
  @@index([sourceSystemId])
}

model FraudSnapshot {
  id                 String          @id @default(cuid())
  entityId           String
  score              Int
  level              String
  bandLabel          String?
  baseScore          Int?
  corroborationCount Int             @default(0)
  activeSignalCount  Int             @default(0)
  explanation        String?
  methodologyVersion String          @default("v1")
  sourceFreshnessAt  DateTime?
  isCurrent          Boolean         @default(true)
  computedAt         DateTime        @default(now())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  entity             CanonicalEntity @relation(fields: [entityId], references: [id])

  @@index([entityId, isCurrent])
  @@index([score])
  @@index([computedAt])
}

model RawArtifact {
  id                String           @id @default(cuid())
  sourceSystemId    String
  ingestionRunId    String?
  entityId          String?
  artifactType      String
  storageProvider   String           @default("local")
  storageKey        String           @unique
  originalUrl       String?
  checksum          String?
  contentType       String?
  byteSize          BigInt?
  sourcePublishedAt DateTime?
  fetchedAt         DateTime         @default(now())
  parsedAt          DateTime?
  parserVersion     String?
  status            String           @default("fetched")
  errorSummary      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  entity            CanonicalEntity? @relation(fields: [entityId], references: [id])
  ingestionRun      IngestionRun?    @relation(fields: [ingestionRunId], references: [id])
  sourceSystem      SourceSystem     @relation(fields: [sourceSystemId], references: [id])

  @@index([sourceSystemId, sourcePublishedAt])
  @@index([ingestionRunId])
  @@index([entityId])
  @@index([status, fetchedAt])
}

model CharityPublication78Record {
  id                String           @id @default(cuid())
  ein               String           @unique
  entityId          String?          @unique
  sourceSystemId    String
  organizationName  String
  city              String?
  state             String?
  countryCode       String?
  deductibilityCode String?
  sourcePublishedAt DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  entity            CanonicalEntity? @relation(fields: [entityId], references: [id])
  sourceSystem      SourceSystem     @relation(fields: [sourceSystemId], references: [id])

  @@index([sourceSystemId])
  @@index([state])
  @@index([deductibilityCode])
}

model CharityEpostcard990NRecord {
  id                    String           @id @default(cuid())
  ein                   String
  entityId              String?
  sourceSystemId        String
  taxYear               Int?
  organizationName      String
  grossReceiptsUnder25K Boolean?
  principalOfficerName  String?
  websiteUrl            String?
  terminated            Boolean?
  taxPeriodBeginDate    DateTime?
  taxPeriodEndDate      DateTime?
  sourcePublishedAt     DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  entity                CanonicalEntity? @relation(fields: [entityId], references: [id])
  sourceSystem          SourceSystem     @relation(fields: [sourceSystemId], references: [id])

  @@unique([ein, taxYear])
  @@index([entityId])
  @@index([sourceSystemId])
  @@index([taxYear])
  @@index([terminated])
}

model CharityFiling990Index {
  id               String       @id @default(cuid())
  objectId         String       @unique
  returnId         String?
  filingType       String?
  ein              String
  taxpayerName     String?
  returnType       String?
  taxPeriod        String?
  subDate          String?
  dln              String?
  lastUpdated      String?
  filingYear       Int?
  sourceSystemId   String
  xmlBatchId       String?
  archiveFileName  String?
  archiveUrl       String?
  archiveEntryPath String?
  xmlUrl           String?
  xmlFetchStatus   String       @default("pending")
  xmlFetchedAt     DateTime?
  parsedAt         DateTime?
  charityFilingId  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  sourceSystem     SourceSystem @relation(fields: [sourceSystemId], references: [id])

  @@index([ein])
  @@index([filingYear])
  @@index([xmlBatchId])
  @@index([archiveFileName])
  @@index([filingYear, archiveFileName])
  @@index([xmlFetchStatus])
  @@index([sourceSystemId])
}

model ConsumerComplaintRecord {
  id                        String          @id @default(cuid())
  sourceSystemId            String
  entityId                  String
  complaintId               String          @unique
  normalizedCompany         String
  dateReceived              DateTime?
  product                   String?
  subProduct                String?
  issue                     String?
  subIssue                  String?
  companyResponse           String?
  timely                    String?
  consumerDisputed          String?
  complaintWhatHappened     String?
  dateSentToCompany         DateTime?
  companyPublicResponse     String?
  companyResponseToConsumer String?
  submittedVia              String?
  state                     String?
  zipCode                   String?
  tags                      String?
  sourceRecordUpdatedAt     DateTime?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  entity                    CanonicalEntity @relation(fields: [entityId], references: [id])
  sourceSystem              SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([entityId, dateReceived])
  @@index([normalizedCompany])
  @@index([product])
  @@index([state])
  @@index([sourceSystemId, sourceRecordUpdatedAt])
}

model ConsumerCompanySummary {
  id                String          @id @default(cuid())
  sourceSystemId    String
  entityId          String          @unique
  totalComplaints   Int             @default(0)
  withRelief        Int             @default(0)
  withoutRelief     Int             @default(0)
  disputedCount     Int             @default(0)
  untimelyCount     Int             @default(0)
  topProduct        String?
  topProductCount   Int?
  latestComplaintAt DateTime?
  sourcePublishedAt DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  entity            CanonicalEntity @relation(fields: [entityId], references: [id])
  sourceSystem      SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([totalComplaints])
  @@index([latestComplaintAt])
  @@index([sourceSystemId, sourcePublishedAt])
}

model HealthcareRecipientProfile {
  id                 String          @id @default(cuid())
  sourceSystemId     String
  entityId           String          @unique
  recipientType      String          @default("physician")
  physicianProfileId String?         @unique
  firstName          String?
  middleName         String?
  lastName           String?
  specialty          String?
  city               String?
  state              String?
  countryCode        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  entity             CanonicalEntity @relation(fields: [entityId], references: [id])
  sourceSystem       SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([lastName, firstName])
  @@index([specialty])
  @@index([state, city])
  @@index([sourceSystemId])
}

model HealthcarePaymentRecord {
  id                    String          @id @default(cuid())
  sourceSystemId        String
  recordId              String          @unique
  paymentType           String
  programYear           Int?
  recipientEntityId     String
  companyEntityId       String
  recipientCity         String?
  recipientState        String?
  physicianFirstName    String?
  physicianLastName     String?
  physicianSpecialty    String?
  manufacturerName      String?
  amountUsd             Float?
  natureOfPayment       String?
  dateOfPayment         DateTime?
  sourceRecordUpdatedAt DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  companyEntity         CanonicalEntity @relation("HealthcareCompanyPayments", fields: [companyEntityId], references: [id])
  recipientEntity       CanonicalEntity @relation("HealthcareRecipientPayments", fields: [recipientEntityId], references: [id])
  sourceSystem          SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([recipientEntityId, dateOfPayment])
  @@index([companyEntityId, dateOfPayment])
  @@index([programYear, paymentType])
  @@index([manufacturerName])
  @@index([physicianLastName, physicianFirstName])
  @@index([sourceSystemId, sourceRecordUpdatedAt])
}

model PoliticalCandidateProfile {
  id                String            @id @default(cuid())
  sourceSystemId    String
  party             String
  office            String?
  state             String
  district          String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  bioguideId        String            @unique
  birthDate         DateTime?
  contactFormUrl    String?
  deathDate         DateTime?
  email             String?
  facebookId        String?
  firstElected      Int?
  firstName         String?
  fullName          String
  gender            String?
  googleEntityId    String?
  lastName          String
  middleName        String?
  nameSuffix        String?
  phone             String?
  profileUrl        String?
  twitterId         String?
  wikipediaUrl      String?
  canonicalEntities CanonicalEntity[]
  sourceSystem      SourceSystem      @relation(fields: [sourceSystemId], references: [id])

  @@index([state, party])
  @@index([lastName, firstName])
  @@index([office])
}

model PoliticalCommitteeProfile {
  id                   String          @id @default(cuid())
  sourceSystemId       String
  entityId             String          @unique
  committeeId          String          @unique
  committeeTypeFull    String?
  committeeType        String?
  designationFull      String?
  partyFull            String?
  state                String?
  treasurerName        String?
  candidateIds         String[]
  cycles               Int[]
  organizationTypeFull String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  entity               CanonicalEntity @relation(fields: [entityId], references: [id])
  sourceSystem         SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([state])
  @@index([committeeType])
  @@index([sourceSystemId])
}

model PoliticalCycleSummary {
  id                                   String          @id @default(cuid())
  sourceSystemId                       String
  entityId                             String
  ownerType                            String
  cycle                                Int
  sourceRecordKey                      String          @unique
  receipts                             Float?
  disbursements                        Float?
  individualContributions              Float?
  otherPoliticalCommitteeContributions Float?
  operatingExpenditures                Float?
  cashOnHandEndPeriod                  Float?
  debtsOwedByCommittee                 Float?
  contributions                        Float?
  lastReportYear                       Int?
  sourceRecordUpdatedAt                DateTime?
  createdAt                            DateTime        @default(now())
  updatedAt                            DateTime        @updatedAt
  entity                               CanonicalEntity @relation(fields: [entityId], references: [id])
  sourceSystem                         SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([entityId, cycle])
  @@index([ownerType, cycle])
  @@index([sourceSystemId, sourceRecordUpdatedAt])
}

model GovernmentAwardRecord {
  id                          String           @id @default(cuid())
  sourceSystemId              String
  generatedInternalId         String           @unique
  internalId                  Int?
  generatedUniqueAwardId      String?
  awardId                     String?
  recipientEntityId           String?
  recipientName               String?
  awardingAgencyName          String?
  fundingAgencyName           String?
  awardAmount                 Float?
  totalOutlays                Float?
  totalObligation             Float?
  baseAndAllOptionsValue      Float?
  description                 String?
  startDate                   DateTime?
  endDate                     DateTime?
  awardType                   String?
  typeDescription             String?
  defCodes                    String[]
  covidSpending               Boolean?
  recipientUei                String?
  recipientBusinessCategories String[]
  placeOfPerformanceCity      String?
  placeOfPerformanceStateCode String?
  placeOfPerformanceCountry   String?
  naics                       String?
  naicsDescription            String?
  pscCode                     String?
  contractPricingDescription  String?
  extentCompetedDescription   String?
  numberOfOffersReceived      Int?
  sourceRecordUpdatedAt       DateTime?
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt
  recipientEntity             CanonicalEntity? @relation("GovernmentAwardRecipient", fields: [recipientEntityId], references: [id])
  sourceSystem                SourceSystem     @relation(fields: [sourceSystemId], references: [id])

  @@index([awardId])
  @@index([recipientName])
  @@index([awardingAgencyName])
  @@index([awardAmount])
  @@index([recipientEntityId])
  @@index([sourceSystemId, sourceRecordUpdatedAt])
}

model CorporateCompanyProfile {
  id                   String          @id @default(cuid())
  sourceSystemId       String
  entityId             String          @unique
  cik                  String          @unique
  entityType           String?
  sic                  String?
  sicDescription       String?
  tickers              String[]
  exchanges            String[]
  stateOfIncorporation String?
  fiscalYearEnd        String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  entity               CanonicalEntity @relation(fields: [entityId], references: [id])
  sourceSystem         SourceSystem    @relation(fields: [sourceSystemId], references: [id])

  @@index([sic])
