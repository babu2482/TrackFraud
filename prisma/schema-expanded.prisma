// TrackFraud - Ultimate Global Fraud & Corruption Tracking Platform
// Comprehensive schema covering EVERY fraud category imaginable across all sectors globally

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE ENTITY RESOLUTION (CanonicalEntity Pattern)
// ============================================

model CanonicalEntity {
  id              String   @id @default(uuid())
  entityType      String   // Individual, Organization, GovernmentBody, CourtCase, etc.
  externalId      String?  // ID from source system
  confidenceScore Float    @default(0.8) // How confident we are this is a real entity

  // Profile data (normalized across sources)
  name            String?
  aliases         EntityAlias[]
  identifiers     EntityIdentifier[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())

  @@index([entityType])
  @@index([externalId])
}

model EntityAlias {
  id          String   @id @default(uuid())
  canonicalEntityId String
  aliasName   String
  source      String?  // Where this alias came from

  canonicalEntity CanonicalEntity @relation(fields: [canonicalEntityId], references: [id], onDelete: Cascade)

  @@index([canonicalEntityId])
}

model EntityIdentifier {
  id          String   @id @default(uuid())
  canonicalEntityId String
  identifierType String // EIN, SSN, Passport, DriverLicense, etc.
  value       String
  issuingCountry String?

  canonicalEntity CanonicalEntity @relation(fields: [canonicalEntityId], references: [id], onDelete: Cascade)

  @@index([canonicalEntityId])
}

// ============================================
// CATEGORY 1: CHARITIES & NONPROFITS (US + Global)
// ============================================

model CharityProfile {
  id              String   @id @default(uuid())
  ein             String?  // US Employer ID Number
  name            String
  legalName       String?
  status          String   // Active, Revoked, Inactive

  // Address & Contact
  address         String?
  city            String?
  state           String?
  zipcode         String?
  country         String? @default("US")

  // Classification
  nteeCode        String?  // National Taxonomy of Exempt Entities
  subsectionCode  String?  // 501(c)(3), etc.

  // Financials (from Form 990)
  totalRevenue    Decimal? @db.Decimal(20, 2)
  totalExpenses   Decimal? @default(0) @db.Decimal(20, 2)
  programExpenses Decimal? @db.Decimal(20, 2) // Money actually spent on programs

  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())

  @@unique([ein])
  @@index([status])
}

