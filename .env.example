# ============================================
# TrackFraud - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ============================================
# Database Configuration
# ============================================
DATABASE_URL="postgresql://trackfraud:trackfraud_dev_password@localhost:5432/trackfraud"
REDIS_URL="redis://localhost:6379"

# PostgreSQL Docker Configuration
POSTGRES_DB=trackfraud
POSTGRES_USER=trackfraud
POSTGRES_PASSWORD=trackfraud_dev_password
POSTGRES_PORT=5432

# Redis Docker Configuration
REDIS_PORT=6379

# ============================================
# Meilisearch Configuration
# ============================================
MEILISEARCH_URL="http://localhost:7700"
MEILISEARCH_API_KEY=trackfraud-dev-master-key
MEILISEARCH_PORT=7700

# ============================================
# Application Configuration
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"
NODE_ENV=development

# Application Ports (host-facing)
# These are used by the start.sh script to configure service ports.
# If a port is already in use, the script will auto-assign the next available port.
NEXT_PUBLIC_APP_PORT=3001
BACKEND_PORT=8000
MEILISEARCH_PORT=7700
PORT_FLOWER=5555

# ============================================
# API Keys (Required/Recommended for Enhanced Data Sources)
# ============================================

# --- Political Transparency APIs ---
# Congress.gov API (optional - demo mode works without key)
CONGRESS_API_KEY=""

# ProPublica Politicians API (REQUIRED for politician data)
PROPUBLICA_API_KEY=""

# ProPublica Nonprofits API (REQUIRED for enhanced nonprofit 990 data)
PROPUBLICA_NONPROFITS_API_KEY=""

# ProPublica Congress API
PROPUBLICA_CONGRESS_API_KEY=""

# OpenSecrets API (lobbying and campaign finance data)
OPENSECRETS_API_KEY=""

# GovTrack US API (legislative tracking)
GOVTRACK_API_KEY=""

# --- SEC & Financial Fraud APIs ---
# SEC EDGAR API (no key required for most endpoints)
SEC_EDGAR_API_KEY=""

# FINRA BrokerCheck API (broker/firm disciplinary disclosures)
FINRA_API_KEY=""

# CFTC Enforcement Actions
CFTC_API_KEY=""

# --- Treasury Sanctions & Financial Crimes ---
# OFAC Sanctions List (no key required - public CSV/JSON)
OFAC_API_KEY=""

# FinCEN (Financial Crimes Enforcement Network)
FINCEN_API_KEY=""

# SAM.gov Exclusions API
SAM_GOV_API_KEY=""

# --- Healthcare Fraud APIs ---
# CMS Data API (for Program Safeguard Exclusions)
CMS_DATA_API_KEY=""

# HHS OIG Exclusion List (no key required - public CSV)
HHS_OIG_API_KEY=""

# FDA OpenFDA API (warning letters, enforcement reports)
FDA_OPENFDA_API_KEY=""

# --- DOJ & Legal Enforcement APIs ---
# DOJ Civil Fraud Recoveries (public data - no key)
DOJ_API_KEY=""

# PACER (Public Access to Court Electronic Records)
PACER_API_KEY=""

# RECAP Archive (court documents)
RECAP_EMAIL=""

# --- Financial/Securities APIs ---
# FINRA BrokerCheck API (broker/firm disciplinary disclosures)
FINRA_API_KEY=""

# --- Environmental APIs ---
# EPA ECHO API (recommended for rate limiting)
EPA_ECHO_API_KEY=""

# --- Federal Register ---
FEDERAL_REGISTER_API_KEY=""

# ============================================
# Data Ingestion Configuration - Source URLs
# ============================================

# --- IRS Tax-Exempt Organizations ---
IRS_EO_BMF_URL="https://www.irs.gov/pub/irs-exempt/eo_bmf.txt"
IRS_AUTO_REVOCATION_URL="https://www.irs.gov/pub/irs-exempt/eo_revoke.txt"
IRS_PUB78_URL="https://www.irs.gov/pub/irs-prior/p5464--2023.pdf"
IRS_990N_URL="https://www.irs.gov/pub/irs-exempt/eo_enpostcard.txt"
IRS_990_XML_BASE_URL="https://www.irs.gov/pub/irs-prior/"

# --- FEC Campaign Finance ---
FEC_API_BASE_URL="https://api.open.fec.gov"
FEC_BULK_DATA_URL="https://www.fec.gov/data/help/bulk-data/"

# --- SEC Securities & Exchange ---
SEC_EDGAR_BASE_URL="https://www.sec.gov"
SEC_ENFORCEMENT_LITIGATION_URL="https://www.sec.gov/litigation/litreleases.shtml"
SEC_ADMINISTRATIVE_PROCEEDINGS_URL="https://www.sec.gov/litigation/admin.shtml"
SEC_CEASE_DESIST_ORDERS_URL="https://www.sec.gov/litigation/cease.shtml"
SEC_ADVISERINFO_BASE_URL="https://adviserinfo.sec.gov"

# --- FINRA BrokerCheck ---
FINRA_API_BASE_URL="https://brokercheck.finra.org/api/v1"

# --- USASpending Government Contracts ---
USASPENDING_API_URL="https://api.usaspending.gov/api/v2/"
USASPENDING_BULK_URL="https://download.usaspending.gov/"

# --- CMS Healthcare Payments & Exclusions ---
CMS_OPEN_PAYMENTS_URL="https://openpaymentsdata.cms.gov"
CMS_PROGRAM_SAFEGUARD_EXCLUSIONS_URL="https://data.cms.gov/dataset/program-safeguard-exclusions"

# --- HHS OIG Healthcare Fraud ---
HHS_OIG_LEIE_CSV_URL="https://data.hhs.gov/api/views/8i6q-9pqr/rows.csv?accessType=DOWNLOAD"
HHS_OIG_EXCLUSIONS_API_URL="https://exclusions.hhs.gov/api/v1/excluded-parties/search"

# --- SAM.gov Excluded Entities ---
SAM_GOV_ENTITY_SEARCH_URL="https://api.sam.gov/api/v1/entity_search"
SAM_GOV_EXCLUSIONS_CSV_URL="https://www.sam.gov/content/sam/public/pages/static_content_files/Excluded_Entities.csv"

# --- CFPB Consumer Complaints ---
CFPB_COMPLAINTS_URL="https://www.consumerfinance.gov/data-research/consumer-complaints/"
CFPB_COMPLAINTS_API_URL="https://www.consumerfinance.gov/data-research/consumer-complaints/files/api/CFPB_complaint_data_dictionary.pdf"

# --- EPA Environmental Enforcement ---
EPA_ECHO_BASE_URL="https://echo.epa.gov"
EPA_ECHO_API_URL="https://echo.epa.gov/static/api/index.html"
EPA_GRANTS_API_URL="https://www.epa.gov/data/grants-api"

# --- FDA Warning Letters & Enforcement ---
FDA_WARNING_LETTERS_URL="https://www.fda.gov/inspections-compliance-enforcement-and-criminal-investigations/compliance-actions-and-activities/warning-letters"
FDA_ENFORCEMENT_REPORTS_URL="https://www.fda.gov/inspections-compliance-enforcement-and-criminal-investigations/enforcement-reports"

# --- FTC Consumer Protection ---
FTC_DATA_BREACH_URL="https://www.ftc.gov/enforcement/data-breaches"
FTC_CONSUMER_PROTECTION_ACTIONS_URL="https://www.ftc.gov/enforcement/cases-proceedings"

# --- DOJ Civil Fraud Recoveries ---
DOJ_CIVIL_FRAUD_URL="https://www.justice.gov/press-releases/subject/civil-fraud-recoveries-over-1-million"
DOJ_HEALTHCARE_FRAUD_URL="https://www.justice.gov/criminal-fraud/health-care-fraud"

# --- Treasury OFAC Sanctions ---
OFAC_SDN_CSV_URL="https://www.treasury.gov/ofac/downloads/sdn.csv"
OFAC_CONSOLIDATED_JSON_URL="https://www.treasury.gov/ofac/downloads/consolidated.json"
OFAC_API_BASE_URL="https://services.officeofforeignassetscontrol.treasury.gov/v1/sanctions"

# --- CFTC Enforcement ---
CFTC_ENFORCEMENT_URL="https://www.cftc.gov/LawEnforcement/enforcementactions"

# --- FinCEN Financial Crimes ---
FINCEN_GEOBASED_URL="https://www.fincen.gov/sites/default/files/Geobased%20Reports.csv"

# --- Federal Register ---
FEDERAL_REGISTER_API_URL="https://www.federalregister.gov/api/v1/documents/"

# --- Congress.gov Legislative Data ---
CONGRESS_GOV_API_URL="https://api.congress.gov/v3"

# --- ProPublica APIs ---
PROPUBLICA_CONGRESS_API_URL="https://api.propublica.org/congress/v1"
PROPUBLICA_NONPROFITS_API_URL="https://projects.propublica.org/nonprofits/api/v2"

# --- OpenSecrets Campaign Finance & Lobbying ---
OPENSECRETS_API_URL="https://www.opensecrets.org/open-data/api"

# ============================================
# Ingestion Settings
# ============================================

# Batch sizes for data processing
INGESTION_BATCH_SIZE=1000

# Rate limiting (requests per minute)
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Retry configuration
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# ============================================
# Storage Configuration
# ============================================

# Local storage path for downloaded files
STORAGE_PATH="./data/raw"

# Maximum file size (in bytes) - 1GB
MAX_FILE_SIZE_BYTES=1073741824

# ============================================
# Logging Configuration
# ============================================

LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=./logs/app.log

# ============================================
# Feature Flags (Optional)
# ============================================

NEXT_PUBLIC_ENABLE_SEARCH=true
NEXT_PUBLIC_ENABLE_FRAUD_SCORING=true
NEXT_PUBLIC_ENABLE_POLITICAL_TRACKING=true
NEXT_PUBLIC_BETA_FEATURES=false

# ============================================
# Security (Production Only)
# ============================================

# JWT Secret for authentication (generate with: openssl rand -base64 32)
JWT_SECRET=""

# Session encryption key (generate with: openssl rand -base64 32)
SESSION_SECRET=""

# CORS origins (comma-separated)
NEXT_PUBLIC_CORS_ORIGINS="http://localhost:3001,http://localhost:3000"

# ============================================
# AI/ML Configuration (Python Backend)
# ============================================

# NLP model paths
SPACY_MODEL=en_core_web_sm
NLTK_DATA_PATH="./backend/nltk_data"

# AI scoring thresholds
CLAIM_DETECTION_THRESHOLD=0.75
PATTERN_CONFIDENCE_MIN=0.60
SENTIMENT_ANALYSIS_ENABLED=true

# ============================================
# External API Keys (Political Data)
# ============================================

# ProPublica Politicians API
PROPUBLICA_API_KEY=""

# Congress.gov API
CONGRESS_API_KEY=""

# GovTrack US API
GOVTRACK_API_KEY=""

# Sunlight Foundation OpenCongress
OPENCONGRESS_API_KEY=""
